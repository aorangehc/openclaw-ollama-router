{
  "name": "openclaw-omni-router",
  "version": "1.0.0",
  "description": "OpenClaw plugin for multimodal Ollama routing with resource awareness and voice support",
  "main": "dist/index.js",
  "type": "module",
  "types": "dist/index.d.ts",
  "openclaw": {
    "extensions": [
      "./openclaw.extension.js"
    ]
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "install:openclaw": "bash scripts/openclaw-install.sh",
    "test:openclaw": "bash scripts/openclaw-smoke-test.sh all",
    "uninstall:openclaw": "bash scripts/openclaw-uninstall.sh",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openclaw",
    "ollama",
    "router",
    "omni",
    "voice",
    "ai",
    "plugin"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.55.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "openclaw.extension.js",
    "scripts",
    "skills",
    "openclaw.plugin.json"
  ],
  "dependencies": {
    "sharp": "^0.34.5"
  }
}
