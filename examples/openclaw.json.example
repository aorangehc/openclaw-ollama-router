{
  "plugins": {
    "load": {
      "paths": [
        "/absolute/path/to/openclaw-ollama-router"
      ]
    },
    "entries": {
      "openclaw-omni-router": {
        "enabled": true,
        "config": {
          "baseUrl": "http://127.0.0.1:11434",
          "allowedModels": [],
          "defaultPreference": "speed",
          "defaultKeepAlive": 0,
          "requestTimeout": 120000
        }
      }
    }
  },
  "skills": {
    "entries": {
      "omni-router": {
        "enabled": true
      }
    }
  },
  "tools": {
    "media": {
      "audio": {
        "enabled": true,
        "provider": "cli",
        "description": "Audio transcription through local Ollama Whisper",
        "cli": {
          "command": "bash",
          "args": [
            "/absolute/path/to/openclaw-ollama-router/scripts/ollama-transcribe.sh",
            "-f",
            "{{MediaPath}}",
            "--model",
            "whisper:latest"
          ],
          "description": "Use the bundled Ollama transcription helper"
        }
      }
    }
  },
  "messages": {
    "tts": {
      "auto": "inbound",
      "provider": "edge",
      "voice": "en-US-AriaNeural",
      "description": "Use Edge TTS and auto reply with voice when the user sends voice"
    }
  },
  "examples": {
      "description": "Example OpenClaw configuration for Omni Router plugin with voice support",
      "notes": [
        "1. Ensure Ollama is running on your machine (ollama serve)",
        "2. Install this plugin into OpenClaw: openclaw plugins install /absolute/path/to/openclaw-ollama-router --link",
        "3. Pull a speech-recognition model into Ollama, for example: ollama pull whisper:latest",
        "4. Configure allowedModels to restrict which models can be used",
        "5. Set preference to 'quality' if you want larger models by default",
        "6. Voice input requires tools.media.audio to be enabled with the bundled Ollama helper",
        "7. Voice output requires messages.tts.auto to be configured"
      ],
      "alternativeConfigs": {
        "taggedTts": {
          "description": "Alternative: Use tagged TTS mode for manual control",
          "messages": {
          "tts": {
            "auto": "tagged"
          }
        }
      },
      "localWhisperCpp": {
        "description": "Alternative: Use whisper.cpp for local transcription",
        "tools": {
          "media": {
            "audio": {
              "cli": {
                "command": "./whisper.cpp/main",
                "args": ["-m", "./whisper.cpp/models/ggml-base.bin", "-f", "{{MediaPath}}"]
              }
            }
          }
        }
      },
      "providerTts": {
        "description": "Alternative: Use OpenAI TTS with API key",
        "messages": {
          "tts": {
            "provider": "openai",
            "providerConfig": {
              "apiKey": "${OPENAI_API_KEY}"
            },
            "voice": "alloy",
            "model": "tts-1"
          }
        }
      }
    }
  }
}
